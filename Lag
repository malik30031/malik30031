-- إحداثيات الانتقال
local TARGET_X = -118.8
local TARGET_Y = 21.5
local TARGET_Z = 245.5

local function TeleportToTarget()
    if LocalPlayer and LocalPlayer.Character then
        local HRP = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if HRP then
            HRP.CFrame = CFrame.new(TARGET_X, TARGET_Y, TARGET_Z)
        end
    end
end

local teleportBtn = createButton("Teleport", 60)
local phoneAutoBtn = createButton("Start Auto Phone", 110)
local phoneCounter = createCounter(160)

--===== نظام الجمع =====--
local phoneAuto = false
local intensity = 2000
local interval = 0.016
local lastTick = 0
local phoneCount = 0

local function getPhone()
    local p = Workspace:FindFirstChild("WorkspaceCom")
    if not p then return end
    local store = p:FindFirstChild("001_CommercialStores")
    if not store then return end
    local c1 = store:FindFirstChild("CommercialStorage1")
    if not c1 then return end
    local tools = c1:FindFirstChild("Store") and c1.Store:FindFirstChild("Tools")
    if not tools then return end
    return tools:FindFirstChild("Iphone")
end

local function collectPhone()
    local phone = getPhone()
    if not phone then return end

    local detector = phone:FindFirstChildOfClass("ClickDetector")
    local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")

    if phone and detector and root then
        root.CFrame = phone.CFrame + Vector3.new(0,2,0)

        if fireclickdetector then
            for i = 1, intensity do

                -- يتوقف فوراً إذا أوقفت الزر
                if not phoneAuto then
                    break
                end

                pcall(function()
                    fireclickdetector(detector)
                end)

            end
        end
    end
end

--===== Anti Lag =====--
local savedObjects = {}

local function hideWorld(state)

    for _, obj in ipairs(Workspace:GetDescendants()) do

        if obj:IsA("BasePart") then

            if state then
                savedObjects[obj] = obj.Transparency
                obj.Transparency = 1
                obj.CanCollide = false

            elseif savedObjects[obj] then
                obj.Transparency = savedObjects[obj]
                obj.CanCollide = true
            end

        end

    end

end

--===== الأزرار =====--

toggle.MouseButton1Click:Connect(function()
    main.Visible = not main.Visible
end)

teleportBtn.MouseButton1Click:Connect(function()
    TeleportToTarget()
end)

phoneAutoBtn.MouseButton1Click:Connect(function()

    phoneAuto = not phoneAuto

    if phoneAuto then
        phoneAutoBtn.Text = "Stop Auto Phone"
        hideWorld(true)
    else
        phoneAutoBtn.Text = "Start Auto Phone"
        hideWorld(false)
    end

end)

--===== تشغيل الجمع =====--

RunService.Heartbeat:Connect(function()

    if tick() - lastTick >= interval then
        lastTick = tick()

        if phoneAuto then
            collectPhone()
            phoneCount += intensity
            phoneCounter.Text = "Collected: "..phoneCount
        end

    end

end)
